# ===========================================
# Beads UI Configuration
# ===========================================

# --- Docker Images ---
SERVICE_IMAGE=ghcr.io/iv/beads-ui:latest

# --- Container Names ---
SERVICE_CONTAINER_NAME=beads-ui

# --- Network Names ---
TRAEFIK_NETWORK_NAME=traefik_default

# --- Traefik Configuration ---
SERVICE_HOST=beads.yourdomain.com
TRAEFIK_CERTRESOLVER=myresolver

# --- Data Path ---
# Point this to a directory that contains a .beads folder (the Beads database)
DATA_PATH=/path/to/your/project/containing/.beads
