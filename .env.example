# ===========================================
# Beads UI Configuration
# ===========================================

# --- Docker Images ---
SERVICE_IMAGE=ghcr.io/korjavin/beads-ui:latest

# --- Container Names ---
SERVICE_CONTAINER_NAME=beads-ui

# --- Network Names ---
TRAEFIK_NETWORK_NAME=traefik_default

# --- Traefik Configuration ---
SERVICE_HOST=beads.yourdomain.com
TRAEFIK_CERTRESOLVER=wildcard

# --- Data Path ---
# Point this to a directory on your host, or a Docker named volume (e.g. beads_data)
# If using GIT_REPO_URL, this path will be used to clone the repo into.
DATA_PATH=/path/to/your/project/containing/.beads

# --- GitHub Git-Ops Sync (Optional) ---
# Set this to a GitHub URL with an embedded token to clone and sync the database.
# Format: https://oauth2:YOUR_GITHUB_TOKEN@github.com/youruser/your-beads-repo.git
GIT_REPO_URL=
GIT_BRANCH=main

# Set to "true" to automatically commit and push changes back to GitHub every 60 seconds
SYNC_ENABLED=false
SYNC_INTERVAL=60
